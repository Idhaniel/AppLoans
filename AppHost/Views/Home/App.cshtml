        function setLoadingDivSize() {
            //console.log("resize");
            let loadingdiv = document.getElementById(pauseoverlayid);

            let loadingdivvisible = $(loadingdiv).is(":visible");
            if (!loadingdivvisible) {
                $(loadingdiv).css("z-index", 0);
                $(loadingdiv).show();
            }

            let divwidth = $(loadingdiv).innerWidth();
            let divheight = $(loadingdiv).innerHeight();

            let loadingimage = document.getElementById("loadingimage");
            let loadingpercentagespan = document.getElementById("loadingpercentagespan");
            let loadingtextspan = document.getElementById("loadingtextspan");
            $(loadingimage).css("left", (divwidth - $(loadingimage).outerWidth()) / 2);
            $(loadingimage).css("top", (divheight - $(loadingimage).outerHeight()) / 2);
            $(loadingpercentagespan).css("top", (divheight - $(loadingpercentagespan).outerHeight()) / 2);
            $(loadingtextspan).css("top", ((divheight - $(loadingtextspan).outerHeight()) / 2) + ($(loadingimage).outerHeight() / 2) + 30); ///* + ($(loadingimage).outerHeight() / 2)*/);

            if (!loadingdivvisible) {
                $(loadingdiv).hide();
            }
        }

        function viewAlert(alertid) {
            let naviframe = document.getElementById("nav-iframe");
            //debugger;
            naviframe.contentDocument.viewAlertEntity(alertid);
            let notificationdetails = document.getElementById('notification-details');
            if (notificationdetails.hasAttribute('visible')) {
                callHook('alerttoggle');
            }
        }

        function markAlertsRead(alertids, read) {
            let alertidsstring = '';
            for (let i = 0; i < alertids.length; i++) {
                alertidsstring += alertids[i];
                if (i < alertids.length - 1) {
                    alertidsstring += ',';
                }
            }
            let markalertsurl = '/Home/MarkAlertsRead?alertidsstring=' + alertidsstring + '&read=' + read;
            $.ajax({
                url: markalertsurl,
                success: function (data) {
                    //debugger;
                    if (data) {
                        for (let i = 0; i < alertids.length; i++) {
                            let alertid = alertids[i];
                            markAlertListItemRead(alertid, read);
                        }
                    }
                }
            });
        }

        function deleteAlert(alertids) {
            let alertidsstring = '';
            for (let i = 0; i < alertids.length; i++) {
                alertidsstring += alertids[i];
                if (i < alertids.length - 1) {
                    alertidsstring += ',';
                }
            }
            let markalertsurl = '/Home/DeleteAlerts?alertidsstring=' + alertidsstring;
            $.ajax({
                type: "POST",
                url: markalertsurl,
                success: function (data) {
                    //debugger;
                    if (data) {
                        for (let i = 0; i < alertids.length; i++) {
                            let alertid = alertids[i];
                            removeAlertListItem(alertid);
                        }
                    }
                }
            });
        }

        function markAlertListItemRead(alertid, read) {
            let alertlistitem = self.top.document.querySelector('#notification-details .notify-box-wrapper[alertid="' + alertid + '"]');
            if (!alertlistitem) {
                //debugger;
            }
            else {
                if (read) {
                    alertlistitem.setAttribute('read', '');
                }
                else {
                    alertlistitem.removeAttribute('read');
                }
            }
        }

        function removeAlertListItem(alertid) {
            let alertlistitem = self.top.document.querySelector('#notification-details .notify-box-wrapper[alertid="' + alertid + '"]');
            $(alertlistitem).remove();
        }

        function closeHamburgerIfMobile() {
            //if mobile display and the menu is open
            if (screen.width <= 900 && $('#content-left').css('display') == 'block') {
                toggle(document.getElementById('content-left'));
            }
        }

        var lastretrieveddatetime = null;
        function getAlerts() {
            let alerturl = '/Home/Alerts?lastretrieveddatetimestring=';
            //if (lastretrieveddatetime) {
            //    alerturl += lastretrieveddatetime
            //}
            $.ajax({
                url: alerturl,
                success: function (data) {
                    lastretrieveddatetime = data.lastalertdatetimestring;
                    let alerts = data.alerts;
                    if (alerts && alerts.length > 0) {
                        let unreadcount = 0;
                        let alertlist = document.getElementById('notification-body');
                        //$(noalertfoundlistitem).css('display', 'none');
                        for (let i = alerts.length - 1; i >= 0; i--) {
                            let alert = alerts[i];

                            if (!alert.alertread) {
                                unreadcount++;
                            }

                            //let li = document.querySelector('li[alertid="' + alert.alertid + '"]')
                            let alertliid = 'alert_li_' + alert.alertid;
                            let notificationbox = document.getElementById(alertliid);
                            if (notificationbox) {
                                continue;
                            }

                            notificationbox = document.createElement('div');
                            notificationbox.setAttribute('id', alertliid);
                            notificationbox.setAttribute('class', 'notify-box-wrapper');
                            notificationbox.setAttribute('alertid', alert.alertid);
                            if (alert.alertread) {
                                notificationbox.setAttribute('read', '');
                            }

                            //li.innerHTML = '<div class="readcheckboxdiv"><input type="checkbox" class="markcheckbox" /></div><div class="alertitemdiv"><div class="alerttitlediv">Sample Alert Sample Alert Sample Alert Sample Alert Sample Alert Sample Alert</div><div class="alertdescriptiondiv"><a href="javascript:void(0)" class="alertitemlink">Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert Alert </a></div></div> <div class="alertbuttonsdiv"><div class="alertbuttondiv"><button>View</button></div><div class="alertbuttondiv"><button>Mark Read</button></div><div class="alertbuttondiv"><button>Delete</button></div></div></li>';
                            let readcheckboxdiv = document.createElement('div');
                            readcheckboxdiv.setAttribute('class', 'notify-checkbox');
                            let markcheckbox = document.createElement('input');
                            markcheckbox.setAttribute('type', 'checkbox');
                            markcheckbox.setAttribute('class', 'markalertcheckbox');
                            markcheckbox.setAttribute('alertid', alert.alertid);

                            readcheckboxdiv.appendChild(markcheckbox);

                            let alertitemdiv = document.createElement('div');
                            alertitemdiv.setAttribute('class', 'notification-row');

                            let alertmenuicondiv = document.createElement('div');
                            alertmenuicondiv.setAttribute('class', 'notification-menu');

                            let alertmenui = document.createElement('i');
                            alertmenui.setAttribute('class', 'subMenuToggler fa fa-ellipsis-h');
                            alertmenui.setAttribute('menuElement', 'alert_menu_' + alert.alertid);

                            subMenuTogglerPerElement(alertmenui);

                            alertmenuicondiv.appendChild(alertmenui);
                            //alerttitlediv.innerText = alert.alerttitle;

                            alertitemdiv.appendChild(alertmenuicondiv);

                            let alertmenudiv = document.createElement('div');
                            alertmenudiv.setAttribute('id', 'alert_menu_' + alert.alertid);
                            alertmenudiv.setAttribute('class', 'overlayMenu notification-menu-buttons-div');
                            $(alertmenudiv).css('display', 'none');

                            let alertmarkreadbutton = document.createElement('button');
                            alertmarkreadbutton.setAttribute('class', 'alertmarkreadbutton');
                            alertmarkreadbutton.innerText = 'Mark Read';
                            alertmarkreadbutton.addEventListener('click', function () {
                                markAlertsRead([alert.alertid], true);
                                toggle(document.getElementById('alert_menu_' + alert.alertid));
                            });

                            let alertmarkunreadbutton = document.createElement('button');
                            alertmarkunreadbutton.setAttribute('class', 'alertmarkunreadbutton');
                            alertmarkunreadbutton.innerText = 'Mark Unread';
                            alertmarkunreadbutton.addEventListener('click', function () {
                                markAlertsRead([alert.alertid], false);
                                toggle(document.getElementById('alert_menu_' + alert.alertid));
                            });

                            let alertdeletebutton = document.createElement('button');
                            alertdeletebutton.innerText = 'Delete';
                            alertdeletebutton.addEventListener('click', function () {
                                deleteAlert([alert.alertid]);
                                toggle(document.getElementById('alert_menu_' + alert.alertid));
                            });

                            alertmenudiv.appendChild(alertmarkreadbutton);
                            alertmenudiv.appendChild(alertmarkunreadbutton)
                            alertmenudiv.appendChild(alertdeletebutton);

                            alertitemdiv.appendChild(alertmenudiv);

                            let alertcontent = document.createElement('a');
                            alertcontent.setAttribute('href', 'javascript:void(0)');
                            alertcontent.setAttribute('class', 'checked-link');

                            let alerttitle = document.createElement('h4');
                            alerttitle.innerText = alert.alerttitle;

                            let alertdescription = document.createElement('p');
                            alertdescription.innerText = alert.alertdescription;

                            alertcontent.appendChild(alerttitle);
                            alertcontent.appendChild(alertdescription);

                            alertcontent.addEventListener('click', function () {
                                viewAlert(alert.alertid);
                                toggle(document.getElementById('notification-details'));
                            });

                            alertitemdiv.appendChild(alertcontent);

                            notificationbox.appendChild(readcheckboxdiv);
                            notificationbox.appendChild(alertitemdiv);

                            $(alertlist).prepend(notificationbox);

                            if (alertlist.querySelectorAll('.notify-box-wrapper').length > maxalerts) {
                                //debugger;
                                $(alertlist.lastChild).remove();
                            }
                        }
                        document.getElementById('notify-count').innerText = unreadcount == 0 ? '' : unreadcount;
                    }
                    else {
                        document.getElementById('notify-count').innerText = '';
                        //$(noalertfoundlistitem).css('display', 'initial');
                    }

                    //var noalertfoundlistitem = document.getElementById('noalertfoundlistitem');

                    //var alertlistitems = document.querySelectorAll('.alertlistitem');
                    //if (alertlistitems.length == 0) {
                    //    $(noalertfoundlistitem).css('display', '');
                    //}
                    //else {
                    //    $(noalertfoundlistitem).css('display', 'none');
                    //}

                    //var unreadcount = document.querySelectorAll('.alertlistitem:not([read])').length;
                    //let unreadalertcountspan = document.getElementById('unreadalertcountspan');
                    //if (unreadcount == 0) {
                    //    unreadalertcountspan.innerText = '';
                    //}
                    //else {
                    //    unreadalertcountspan.innerText = unreadcount;
                    //}

                    //console.log(data);
                }
            });
        }

        function clearInterfaceSettings() {
            clearAllViewCookies();
            toggle(document.getElementById('profile-drop-down'));
            alert('Interface settings cleared');
        }

        $(function () {
            let pausewindowinterval = setInterval(function () {
                if (appframeworkprepared) {
                    clearInterval(pausewindowinterval);
                    pauseWindow();
                    setTimeout(unpauseWindow, 5000);
                }
            }, 200);

            let markallalertscheckbox = document.getElementById('markallalertscheckbox');
            markallalertscheckbox.onchange = function () {
                setTimeout(function () {
                    //debugger;
                    let tickedalertcheckboxes = document.querySelectorAll('.markalertcheckbox');
                    for (let i = 0; i < tickedalertcheckboxes.length; i++) {
                        let checkbox = tickedalertcheckboxes[i];
                        checkbox.checked = markallalertscheckbox.checked;
                    }
                })
            }

            let markallalertsreadbutton = document.getElementById('markallalertsreadbutton');
            markallalertsreadbutton.addEventListener('click', function () {
                let tickedalertcheckboxes = document.querySelectorAll('.markalertcheckbox');
                let alertids = [];
                for (let i = 0; i < tickedalertcheckboxes.length; i++) {
                    let checkbox = tickedalertcheckboxes[i];
                    if (checkbox.checked) {
                        alertids.push(checkbox.getAttribute('alertid'));
                    }
                }
                markAlertsRead(alertids, true);
            });

            let markallalertsunreadbutton = document.getElementById('markallalertsunreadbutton');
            markallalertsunreadbutton.addEventListener('click', function () {
                let tickedalertcheckboxes = document.querySelectorAll('.markalertcheckbox');
                let alertids = [];
                for (let i = 0; i < tickedalertcheckboxes.length; i++) {
                    let checkbox = tickedalertcheckboxes[i];
                    if (checkbox.checked) {
                        alertids.push(checkbox.getAttribute('alertid'));
                    }
                }
                markAlertsRead(alertids, false);
            });

            let deleteallalertsbutton = document.getElementById('deleteallalertsbutton');
            deleteallalertsbutton.addEventListener('click', function () {
                let tickedalertcheckboxes = document.querySelectorAll('.markalertcheckbox');
                let alertids = [];
                for (let i = 0; i < tickedalertcheckboxes.length; i++) {
                    let checkbox = tickedalertcheckboxes[i];
                    if (checkbox.checked) {
                        alertids.push(checkbox.getAttribute('alertid'));
                    }
                }
                if (confirm('Are you sure you want to delete all marked alerts')) {
                    deleteAlert(alertids);
                }
            });

            getAlerts();

            if (debug) {
                setInterval(getAlerts, 60000);
            }
            else {
                setInterval(getAlerts, 10000);
            }

            setLoadingDivSize();
            setInterval(function () {
                if (windowPaused()) {
                    setLoadingDivSize();
                }
            }, 1000);

            window.addEventListener("resize", setLoadingDivSize);

            setInterval(function () {
                let loadingdiv = document.getElementById(pauseoverlayid);

                let percentage = loadingdiv.getAttribute("progress");

                let loadingtext = loadingdiv.getAttribute("progresstext");
                if (!loadingtext) {
                    loadingtext = "Loading...";
                }

                let percentageint = parseInt(percentage);

                if (percentageint == 0 || !percentage) {
                    percentage = "";
                }
                else {
                    if (percentageint < 10) {
                        percentage = "0" + percentageint.toString();
                    }
                    else if (percentageint > 99) {
                        //console.log(percentage);
                        percentage = 99;
                    }
                    else {
                        percentage = percentageint.toString();
                    }
                    percentage = percentage + "%";
                }
                let loadingpercentagespan = document.getElementById("loadingpercentagespan");
                loadingpercentagespan.innerText = percentage;
                let loadingtextspan = document.getElementById("loadingtextspan");
                loadingtextspan.innerText = loadingtext;
            }, 1000);

            let setclearinfologclassinterval = setInterval(function () {
                let clearinfologbutton = document.getElementById("clearinfologbutton");
                if (clearinfologbutton) {
                    clearTimeout(setclearinfologclassinterval);
                    $(clearinfologbutton).addClass("fa");
                    $(clearinfologbutton).addClass("fa-close");
                }
            }, 50);

            //let alertbutton = document.getElementById('alert');
            //alertbutton.addEventListener('click', function () {
            //    callHook('alerttoggle');
            //});

            //let alertdiv = document.getElementById('alertdiv');
            ////$(alertdiv).css();

            ////debugger;
            //registerHook("alerttoggle", function () {
            //    //debugger;
            //    closeHamburgerIfMobile();
            //    if (alertdiv.hasAttribute('visible')) {
            //        alertdiv.removeAttribute('visible');
            //    }
            //    else {
            //        alertdiv.setAttribute('visible', '');
            //    }
            //});
        });
    </script>

