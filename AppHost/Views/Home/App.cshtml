        </div><!-- end header left div -->
        <div id="header-right">
            <div id="profile-settings">
                <p class="menuToggler clickable" menuElement="profile-drop-down">@Session["name"]<span class="drop-down-btn"><i class="fa fa-angle-down menuToggler" menuElement="profile-drop-down"></i></span></p>
                <div id="profile-drop-down" class="overlayMenu" style="display: none;">
                    <ul>
                        <li><a href="javascript:void(0)" onclick="changePassword()"><i class="fa fa-gear"></i>change password</a></li>
                        @*<li><a href="javascript:void(0)" onclick="setColorScheme()"><i class="fa fa-clone"></i>change colour scheme</a></li>*@
                        <li><a href="javascript:void(0)" onclick="clearInterfaceSettings()"><i class="fa fa-eraser"></i>clear interface settings</a></li>
                        <li><a href="~/Home/Logout"><i class="fa fa-power-off"></i>logout</a></li>
                    </ul>
                </div>
            </div>
            <div id="notification">
                <div id="notify-btn">
                    <i class="fa fa-bell menuToggler" menuElement="notification-details"></i>
                    <span id="notify-count" class="menuToggler" menuElement="notification-details"></span>
                </div>
                <div id="notification-details" class="overlayMenu" style="display: none;">
                    <div class="notification-heading">
                        <div class="notification-heading-left">
                            <input type="checkbox" id="markallalertscheckbox" /> |
                            <button id="markallalertsreadbutton">Mark all Read</button> |
                            <button id="markallalertsunreadbutton">Mark all unread</button>
                        </div>
                        <div class="notification-heading-right">
                            <button id="deleteallalertsbutton"><span><i class="fa fa-trash"></i></span>Delete all</button>
                        </div>
                    </div><!-- end notification heading here -->
                    <div id="notification-body">
                    </div>
                </div><!-- end notification details here -->
            </div><!-- end notification div here -->
            <div id="company-name">
                <h1><span id="company-name-value" class="menuToggler clickable" menuElement="company-list">@ViewBag.CurrentCompany</span><i class="fa fa-angle-down menuToggler" menuElement="company-list"></i></h1>
                <div id="company-list" class="overlayMenu" style="display: none">
                    <ul>
                        @{
                            var companies = ViewBag.Companies;
                        }
                        @foreach (var company in companies)
                        {
                            <li><a href="javascript:void(0)" onclick="changeCompany('@company.CompanyID')">@company.CompanyID</a></li>
                        }
                    </ul>
                </div>
            </div>
        </div><!-- end header-right div -->
    </header>
    <div id="content">
        <div id="content-left">
            <iframe id="nav-iframe" style="width:100%; height:100%"></iframe>
        </div>
        <div class="content-right" id="appcontainer">
            <div id="dashboardreports" style="width: 100%; height: 100%; top: 0px; opacity: 1; position: absolute; z-index: 6; display: flex; flex-flow: column; display:none"></div>
            <div id="infologdiv" class="infologdiv"></div>
        </div>
    </div>

    <div id="loadingdiv" style="opacity:0.5; background-color:white; overflow:hidden; height:100vh">
        <img id="loadingimage" src="~/Content/loading3.gif" style="position: absolute" />
        <span id="loadingpercentagespan" style="position: absolute; font-size: 90px; width:100%; text-align:center">&nbsp;&nbsp;</span>
        <span id="loadingtextspan" style="position: absolute; font-size: 30px; width:100%; text-align:center">Loading...</span>
    </div>
    <script type="text/javascript" src="~/js/formalScript.js"></script>
</body>
</html>
