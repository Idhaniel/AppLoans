        function createSavedReportIFrames(iframeids) {
            //debugger;
            let dashboardreports = document.getElementById('dashboardreports');
            dashboardreports.innerHTML = '';

            let height = $('#dashboardreports').innerHeight() * 0.5;
            //let i = 0;
            //for (let i = 0; i < iframeids.length; i++) {
            let createreportdivfunction = function (i) {
                let dashboardreportdiv = document.createElement('div');
                $(dashboardreportdiv).height(height);
                $(dashboardreportdiv).addClass("col-sm-6");
                $(dashboardreportdiv).addClass("col-xs-12");
                $(dashboardreportdiv).addClass("dashboardreportdiv");
                dashboardreportdiv.setAttribute('id', 'dashboardreportcontainer_' + iframeids[i]);

                let dashboardreportiframe = document.createElement('iframe');
                let deletediv = document.createElement('div');
                deletediv.setAttribute('class', 'deletesavedreportdiv');

                let moveuplink = document.createElement('a');
                moveuplink.innerText = 'Move Up';
                moveuplink.setAttribute('href', 'javascript:void(0)');
                moveuplink.setAttribute('savedreportindex', i);
                moveuplink.setAttribute('class', 'moveupreportlink dashboardreportcontrollink');
                moveuplink.setAttribute('onclick', 'moveUpDashboardReport(this);');
                deletediv.appendChild(moveuplink);

                let movedownlink = document.createElement('a');
                movedownlink.innerText = 'Move Down';
                movedownlink.setAttribute('href', 'javascript:void(0)');
                movedownlink.setAttribute('savedreportindex', i);
                movedownlink.setAttribute('class', 'movedownreportlink dashboardreportcontrollink');
                movedownlink.setAttribute('onclick', 'moveDownDashboardReport(this);');
                deletediv.appendChild(movedownlink);

                //let deletelink = document.createElement('a');
                //deletelink.innerText = 'Delete Report';
                //deletelink.setAttribute('href', 'javascript:void(0)');
                //deletelink.setAttribute('savedreportindex', i);
                //deletelink.setAttribute('class', 'deletesavedreportlink dashboardreportcontrollink');
                //deletelink.setAttribute('onclick', 'deleteDashboardReport(this);');
                //deletediv.appendChild(deletelink);

                let deletelink = document.createElement('a');
                deletelink.innerText = 'Delete Report';
                deletelink.setAttribute('href', 'javascript:void(0)');
                deletelink.setAttribute('savedreportindex', i);
                deletelink.setAttribute('class', 'deletesavedreportlink dashboardreportcontrollink');
                deletelink.setAttribute('onclick', 'deleteDashboardReport(this);');
                deletediv.appendChild(deletelink);

                dashboardreportiframe.setAttribute('id', iframeids[i]);
                dashboardreportiframe.setAttribute('class', 'dashboardreportiframe');
                //$(dashboardreportiframe).css('border-style', 'none');
                //$(dashboardreportiframe).css('display', 'none');

                dashboardreportdiv.appendChild(dashboardreportiframe);
                dashboardreportdiv.appendChild(deletediv);

                dashboardreports.appendChild(dashboardreportdiv);


                prepareIframe(dashboardreportiframe, function () {
                    //i++;
                    if (i < iframeids.length - 1) {
                        createreportdivfunction(i + 1);
                    }
                });
            };
            if (iframeids.length > 0) {
                createreportdivfunction(0);
            }

            //}

        }

