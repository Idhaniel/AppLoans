
@{
    Layout = null;
    //ViewBag.Title = ViewBag.ApplicationName + " Login";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewBag.ApplicationName + " Login")</title>
    <link rel="stylesheet" type="text/css" href="~/css/login.css">
    <link rel="stylesheet" type="text/css" href="~/css/responsive.css">
    @*<link rel="stylesheet" type="text/css" href="~/css/bootstrap.css">*@
    <!-- font links -->
    <link href="https://fonts.googleapis.com/css?family=Fira+Sans" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=PT+Sans" rel="stylesheet">
    <link href="~/images/favicon.ico" rel="shortcut icon">
    <script src="~//Scripts/fingerprint2.js"></script>
    <style>
        .alert:empty {
            display: none;
        }
        .alert {
            font-size: 0.8125em;
            margin-top: -25px;
            margin-bottom: 25px;
            display: block;
            color: #e68383;
            background: rgba(255, 230, 245, 0.45);
            width: 84%;
            padding: 6px;
            border-radius: 3px 3px 3px 3px;
            line-height: 21px;
        }
        #twofactorauthdiv {
            display: none
        }
        #loginreset {
            float: right;
            display: none;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="content-login">
        <div class="form-wrapper">
            <div class="form-heading">
                <img src="~/images/logo.jpg" alt="logo">
            </div>
            <form method="post" id="loginform" autocomplete="off">
                <div id="errordiv" class="alert alert-danger">@ViewBag.Error</div>
                <div id="successdiv" class="alert alert-success">@ViewBag.Success</div>
                <div id="warningdiv" class="alert alert-warning">@ViewBag.Warning</div>
                <div class="group1">
                    <input type="text" placeholder="username" name="username" id="username" autocomplete="off">
                </div>
                <div class="group2">
                    <input type="password" placeholder="password" name="password" id="password" autocomplete="off">
                </div>
                <div class="group2" id="twofactorauthdiv">
                    <input type="text" placeholder="auth code" name="twofactorauthtoken" id="authcode" autocomplete="off">
                </div>
                <div id="login">
                    <div class="login-wrap">
                        <input type="submit" value="login" id="loginbutton">
                        <a href="/Home/Logout" role="button" id="loginreset">Reset</a>
                    </div>
                </div>
                <input type="hidden" id="browserfingerprint" name="browserfingerprint" />
            </form>
            <form method="post" id="postloginform" style="display: none">
                <input type="hidden" id="porttouse" name="porttouse" />
                <input type="hidden" id="antiforgerytoken" name="antiforgerytoken" />
            </form>
        </div><!-- end form wrapper here -->
    </div><!-- end content-login here -->
    @*<script src="https://code.jquery.com/jquery-2.2.4.min.js" integrity="sha256-BbhdlvQf/xTY9gja0Dq3HiwQF8LaCRTXxZKRutelT44=" crossorigin="anonymous"></script>*@
    <script src="~/Scripts/jquery-3.js?" type="text/javascript"></script>

    <!-- to maintain background image height on all window -->
    <script type="text/javascript">
        //String.prototype.hashCode = function () {
        //    var hash = 0;
        //    if (this.length == 0) {
        //        return hash;
        //    }
        //    for (var i = 0; i < this.length; i++) {
        //        var char = this.charCodeAt(i);
        //        hash = ((hash << 5) - hash) + char;
        //        hash = hash & hash; // Convert to 32bit integer
        //    }
        //    return hash;
        //};

        $(document).ready(function () {
            function setHeight() {
                windowHeight = $(window).innerHeight();
                $('.content-login').css('min-height', windowHeight);
            };
            setHeight();

            $(window).resize(function () {
                setHeight();
            });

            let loginform = document.getElementById('loginform');
            loginform.addEventListener('submit', function (event) {
                event.preventDefault();

                login();
            });

            //if (window.requestIdleCallback) {
            //    requestIdleCallback(function () {
            //        Fingerprint2.get(function (components) {
            //            let componentsstr = JSON.stringify(components);
            //            console.log(componentsstr) // an array of components: {key: ..., value: ...}
            //        });
            //    })
            //} else {
            //    setTimeout(function () {
            //        Fingerprint2.get(function (components) {
            //            let componentsstr = JSON.stringify(components);
            //            console.log(componentsstr) // an array of components: {key: ..., value: ...}
            //        })
            //    }, 500)
            //}
        });

        function login() {
            let usernamefield = document.getElementById('username');
            let passwordfield = document.getElementById('password');
            let authcodefield = document.getElementById('authcode');
            let username = usernamefield.value;
            let password = passwordfield.value;
            let authcode = authcodefield.value;

            let loginbutton = document.getElementById('loginbutton');

            loginbutton.setAttribute('disabled', '');
            usernamefield.setAttribute('disabled', '');
            passwordfield.setAttribute('disabled', '');
            authcodefield.setAttribute('disabled', '');
            loginbutton.setAttribute('value', 'Logging In...');

            Fingerprint2.get(function (components) {
                let componentsstr = JSON.stringify(components);
                let fingerprinthashcode = componentsstr;

                document.getElementById('browserfingerprint').value = componentsstr;

                console.log(fingerprinthashcode) // an array of components: {key: ..., value: ...}
                
                $.ajax({
                    type: "POST",
                    url: '/Home/Login',
                    data: { username: username, password: password, browserfingerprint: componentsstr, twofactorauthtoken: authcode },
                    success: function (data) {
                        console.log(data);
                        if (data.result < 1) {
                            let errordiv = document.getElementById('errordiv');
                            errordiv.innerText = data.error;
                            warningdiv.innerText = '';
                            loginbutton.setAttribute('value', 'Login');
                        }
                        else if (data.result == 1) {
                            let warningdiv = document.getElementById('warningdiv');
                            warningdiv.innerText = data.message;
                            errordiv.innerText = '';
                            $('#twofactorauthdiv').css('display', 'block');

                            let loginreset = document.getElementById('loginreset');
                            $('#loginreset').css('display', 'inline-block');

                            loginbutton.setAttribute('value', 'Login');
                        }
                        else if (data.result == 2) {
                            let postloginform = document.getElementById('postloginform');
                            postloginform.setAttribute('action', data.url);
                            let porttouse = document.getElementById('porttouse');
                            porttouse.value = data.porttouse;
                            let antiforgerytoken = document.getElementById('antiforgerytoken');
                            if (data.antiforgerytoken) {
                                antiforgerytoken.value = data.antiforgerytoken;
                            }
                            else {
                                antiforgerytoken.value = '';
                            }
                            postloginform.submit();
                            //window.location = data.url;
                        }
                        loginbutton.removeAttribute('disabled');
                        usernamefield.removeAttribute('disabled');
                        passwordfield.removeAttribute('disabled');
                        authcodefield.removeAttribute('disabled');
                    },
                    error: function (data) {
                        loginbutton.removeAttribute('disabled');
                        usernamefield.removeAttribute('disabled');
                        passwordfield.removeAttribute('disabled');
                        authcodefield.removeAttribute('disabled');
                        loginbutton.setAttribute('value', 'Login');
                        console.log(data);
                    },
                    dataType: 'json'
                });
                //post username, password, and hashcode
                
                //if return -1, then show error
                //if return 1, then ask for two factor auth code
                //if return 2, then redirect to supplied url

            });
        }
    </script>
    @Scripts.Render("~/bundles/bootstrap")
</body>
</html>

